#!/bin/bash
#SBATCH --account=e32695
#SBATCH --partition=gengpu
#SBATCH --gres=gpu:h100:1
#SBATCH --time=02:00:00
#SBATCH --mem=128G
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --job-name=magihuman_container_setup
#SBATCH --output=/scratch/cia5572/magihuman_cache_dit_bench/container_setup-%j.out
#SBATCH --error=/scratch/cia5572/magihuman_cache_dit_bench/container_setup-%j.err
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=mingyezhang2026@u.northwestern.edu

set -euo pipefail

SUBMIT_DIR="${SLURM_SUBMIT_DIR:-$(pwd)}"
REPO_DIR="${REPO_DIR:-}"
if [[ -n "${REPO_DIR}" ]]; then
    :
elif [[ -f "${SUBMIT_DIR}/pyproject.toml" && -d "${SUBMIT_DIR}/vllm_omni" ]]; then
    REPO_DIR="${SUBMIT_DIR}"
elif [[ -f "${SUBMIT_DIR}/../../pyproject.toml" && -d "${SUBMIT_DIR}/../../vllm_omni" ]]; then
    REPO_DIR="$(cd "${SUBMIT_DIR}/../.." && pwd)"
else
    REPO_DIR="/home/cia5572/vllm-omni"
fi

if [[ ! -f "${REPO_DIR}/pyproject.toml" || ! -d "${REPO_DIR}/vllm_omni" ]]; then
    echo "Could not locate vllm-omni repo. Set REPO_DIR=/path/to/vllm-omni when submitting." >&2
    echo "Tried REPO_DIR=${REPO_DIR} and SLURM_SUBMIT_DIR=${SUBMIT_DIR}" >&2
    exit 1
fi

APPTAINER_IMAGE="${APPTAINER_IMAGE:-/scratch/cia5572/containers/vllm-openai-v0.19.0.sif}"
APPTAINER_URI="${APPTAINER_URI:-docker://vllm/vllm-openai:v0.19.0}"
CONTAINER_RUNTIME="${CONTAINER_RUNTIME:-}"
ENV_DIR="${ENV_DIR:-/scratch/cia5572/venvs/vllm-omni-magihuman-container}"
HF_CACHE_DIR="${HF_CACHE_DIR:-/scratch/cia5572/hf_cache}"
TMPDIR="${TMPDIR:-/scratch/cia5572/tmp}"
VLLM_RPC_BASE_PATH="${VLLM_RPC_BASE_PATH:-/scratch/cia5572/vllm_rpc}"
MAGI_COMPILER_DIR="${MAGI_COMPILER_DIR:-/scratch/cia5572/MagiCompiler}"
SETUP_SCRIPT="${SETUP_SCRIPT:-${HOME}/setup_vllm_omni_magihuman_container_env.sh}"
RESET_ENV="${RESET_ENV:-0}"

mkdir -p /scratch/cia5572/magihuman_cache_dit_bench /scratch/cia5572/containers "${HF_CACHE_DIR}" "${TMPDIR}" "${VLLM_RPC_BASE_PATH}" "$(dirname "${ENV_DIR}")"

module load singularity/3.8.1 || true

if [[ -z "${CONTAINER_RUNTIME}" ]]; then
    if command -v apptainer >/dev/null 2>&1; then
        CONTAINER_RUNTIME="apptainer"
    elif command -v singularity >/dev/null 2>&1; then
        CONTAINER_RUNTIME="singularity"
    else
        echo "Neither apptainer nor singularity is available. Load a singularity module first." >&2
        exit 1
    fi
fi

if [[ ! -f "${APPTAINER_IMAGE}" ]]; then
    "${CONTAINER_RUNTIME}" pull "${APPTAINER_IMAGE}" "${APPTAINER_URI}"
fi

if [[ ! -d "${MAGI_COMPILER_DIR}" ]]; then
    git clone https://github.com/SandAI-org/MagiCompiler.git "${MAGI_COMPILER_DIR}"
fi

if [[ -d "${ENV_DIR}" && "${RESET_ENV}" == "1" ]]; then
    rm -rf "${ENV_DIR}"
fi

"${CONTAINER_RUNTIME}" exec --nv \
    --bind "${REPO_DIR}:${REPO_DIR}" \
    --bind "/scratch/cia5572:/scratch/cia5572" \
    --bind "${HOME}:${HOME}" \
    "${APPTAINER_IMAGE}" \
    bash -lc "
        set -euo pipefail
        cd '${REPO_DIR}'
        nvidia-smi
        python3 -m venv '${ENV_DIR}'
        source '${ENV_DIR}/bin/activate'
        python -m pip install --upgrade pip setuptools wheel ninja packaging numpy
        python -m pip install 'vllm==0.19.0'
        export VLLM_OMNI_TARGET_DEVICE=cuda
        python -m pip install -e .
        python -m pip install -r '${MAGI_COMPILER_DIR}/requirements.txt'
        python -m pip install -e '${MAGI_COMPILER_DIR}'
        python - <<'PY'
import cache_dit
import torch
import vllm
import vllm_omni

print(f'torch={torch.__version__}, cuda={torch.version.cuda}')
print(f'CUDA available: {torch.cuda.is_available()}, devices={torch.cuda.device_count()}')
print(f'vLLM={vllm.__version__}, cache_dit={cache_dit.__version__}')
print('vllm_omni import OK')
PY
    "

cat > "${SETUP_SCRIPT}" <<EOF
# Auto-generated by ${0}
export APPTAINER_IMAGE="${APPTAINER_IMAGE}"
export CONTAINER_RUNTIME="${CONTAINER_RUNTIME}"
export VLLM_OMNI_CONTAINER_ENV="${ENV_DIR}"
export HF_HOME="${HF_CACHE_DIR}"
export HF_HUB_CACHE="${HF_CACHE_DIR}/hub"
export TMPDIR="${TMPDIR}"
export VLLM_RPC_BASE_PATH="${VLLM_RPC_BASE_PATH}"
export VLLM_WORKER_MULTIPROC_METHOD=spawn
EOF
chmod +x "${SETUP_SCRIPT}"

echo "Container setup complete."
echo "Runtime: ${CONTAINER_RUNTIME}"
echo "Image: ${APPTAINER_IMAGE}"
echo "Container venv: ${ENV_DIR}"
echo "Setup script: ${SETUP_SCRIPT}"
