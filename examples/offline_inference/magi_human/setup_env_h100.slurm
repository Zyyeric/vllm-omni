#!/bin/bash
#SBATCH --account=e32695
#SBATCH --partition=gengpu
#SBATCH --gres=gpu:h100:1
#SBATCH --time=02:00:00
#SBATCH --mem=128G
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --job-name=magihuman_env_setup
#SBATCH --output=/scratch/cia5572/magihuman_cache_dit_bench/env_setup-%j.out
#SBATCH --error=/scratch/cia5572/magihuman_cache_dit_bench/env_setup-%j.err
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=mingyezhang2026@u.northwestern.edu

set -euo pipefail

SUBMIT_DIR="${SLURM_SUBMIT_DIR:-$(pwd)}"
cd "${SUBMIT_DIR}"
if [[ -f "pyproject.toml" && -d "vllm_omni" ]]; then
    REPO_DIR="${PWD}"
elif [[ -f "../../pyproject.toml" && -d "../../vllm_omni" ]]; then
    REPO_DIR="$(cd ../.. && pwd)"
else
    echo "Submit this job from the vllm-omni repo root or examples/offline_inference/magi_human." >&2
    exit 1
fi
cd "${REPO_DIR}"

ENV_DIR="${ENV_DIR:-${HOME}/.venvs/vllm-omni-magihuman}"
SETUP_SCRIPT="${SETUP_SCRIPT:-${HOME}/setup_vllm_omni_magihuman_env.sh}"
HF_CACHE_DIR="${HF_CACHE_DIR:-/scratch/cia5572/hf_cache}"
RESET_ENV="${RESET_ENV:-0}"
BUILD_VLLM_FROM_SOURCE="${BUILD_VLLM_FROM_SOURCE:-0}"

mkdir -p /scratch/cia5572/magihuman_cache_dit_bench "${HF_CACHE_DIR}"

echo "Setting up vLLM-Omni MagiHuman env on an allocated H100"
nvidia-smi

if [[ -d "${ENV_DIR}" && "${RESET_ENV}" == "1" ]]; then
    echo "RESET_ENV=1; removing existing environment at ${ENV_DIR}"
    rm -rf "${ENV_DIR}"
fi

if [[ -d "${ENV_DIR}" ]]; then
    echo "Reusing existing environment at ${ENV_DIR}"
else
    uv venv --python 3.12 --seed "${ENV_DIR}"
fi
source "${ENV_DIR}/bin/activate"

uv pip install --upgrade pip setuptools wheel ninja packaging numpy
export VLLM_TARGET_DEVICE=cuda
if ! uv pip install "vllm==0.19.0" --torch-backend=auto --only-binary vllm; then
    if [[ "${BUILD_VLLM_FROM_SOURCE}" != "1" ]]; then
        echo "No usable vLLM wheel was found for this node." >&2
        echo "If the node OS is too old for the wheel, rerun with BUILD_VLLM_FROM_SOURCE=1 after loading gcc/g++ >= 12.3 and CUDA." >&2
        exit 1
    fi
    echo "BUILD_VLLM_FROM_SOURCE=1; building vLLM from source with VLLM_TARGET_DEVICE=${VLLM_TARGET_DEVICE}"
    uv pip install "vllm==0.19.0" --torch-backend=auto --no-build-isolation
fi

export VLLM_OMNI_TARGET_DEVICE=cuda
uv pip install -e .

MAGI_COMPILER_DIR="${MAGI_COMPILER_DIR:-/scratch/cia5572/MagiCompiler}"
if [[ ! -d "${MAGI_COMPILER_DIR}" ]]; then
    git clone https://github.com/SandAI-org/MagiCompiler.git "${MAGI_COMPILER_DIR}"
fi
uv pip install -r "${MAGI_COMPILER_DIR}/requirements.txt"
uv pip install -e "${MAGI_COMPILER_DIR}"

cat > "${SETUP_SCRIPT}" <<EOF
# Auto-generated by ${0}
source "${ENV_DIR}/bin/activate"
export HF_HOME="${HF_CACHE_DIR}"
export HF_HUB_CACHE="${HF_CACHE_DIR}/hub"
export VLLM_WORKER_MULTIPROC_METHOD=spawn
EOF

chmod +x "${SETUP_SCRIPT}"

python - <<'PY'
import cache_dit
import torch
import vllm
import vllm_omni

print(f"torch={torch.__version__}, cuda={torch.version.cuda}")
print(f"CUDA available: {torch.cuda.is_available()}, devices={torch.cuda.device_count()}")
print(f"vLLM={vllm.__version__}, cache_dit={cache_dit.__version__}")
print("vllm_omni import OK")
PY

echo "Environment setup complete: ${ENV_DIR}"
echo "Batch setup script written: ${SETUP_SCRIPT}"
